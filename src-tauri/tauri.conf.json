{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "个人工作面板",
  "version": "1.2.0",
  "identifier": "com.local.personal-work-panel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "个人工作面板",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 600,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**",
          "$LOCALDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
